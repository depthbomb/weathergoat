generator client {
  provider     = "prisma-client"
  runtime      = "bun"
  output       = "../src/database/generated"
  moduleFormat = "esm"
}

datasource db {
  provider = "sqlite"
}

model AlertDestination {
  id            Int     @id @default(autoincrement())
  snowflake     String  @unique
  latitude      String
  longitude     String
  zoneId        String
  countyId      String
  guildId       String
  channelId     String
  autoCleanup   Boolean @default(true)
  radarImageUrl String?
  pingOnSevere  Boolean @default(false)

  @@index([guildId])
}

model AutoRadarMessage {
  id            Int      @id @default(autoincrement())
  snowflake     String   @unique
  guildId       String
  channelId     String
  messageId     String   @unique
  location      String
  radarStation  String
  radarImageUrl String
  nextUpdate    DateTime @default(now())

  @@index([guildId, nextUpdate])
}

model ForecastDestination {
  id            Int     @id @default(autoincrement())
  snowflake     String  @unique
  latitude      String
  longitude     String
  guildId       String
  channelId     String
  messageId     String  @unique
  radarImageUrl String?

  @@index([guildId])
}

model SentAlert {
  id        Int    @id @default(autoincrement())
  alertId   String
  guildId   String
  channelId String
  messageId String

  @@unique([alertId, guildId, channelId])
  @@index([guildId, channelId, alertId])
}

model VolatileMessage {
  id        Int      @id @default(autoincrement())
  guildId   String
  channelId String
  messageId String   @unique
  expiresAt DateTime

  @@index([expiresAt])
}

model FeedbackBan {
  id        Int      @id @default(autoincrement())
  userId    String   @unique
  reason    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Announcement {
  id         Int                    @id @default(autoincrement())
  snowflake  String                 @unique
  title      String
  body       String
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  deliveries AnnouncementDelivery[]
}

model AnnouncementSubscription {
  id         Int                    @id @default(autoincrement())
  guildId    String                 @unique
  channelId  String
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  deliveries AnnouncementDelivery[]
}

model AnnouncementDelivery {
  id             Int                      @id @default(autoincrement())
  announcementId Int
  subscriptionId Int
  sentAt         DateTime?
  failedAt       DateTime?
  error          String?
  createdAt      DateTime                 @default(now())
  announcement   Announcement             @relation(fields: [announcementId], references: [id])
  subscription   AnnouncementSubscription @relation(fields: [subscriptionId], references: [id])

  @@unique([announcementId, subscriptionId])
  @@index([announcementId])
  @@index([subscriptionId])
}
